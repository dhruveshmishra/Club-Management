{
  "name": "Club-Management",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "dotenv -e .env -- turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "^10.0.0 || ^11.0.0"
    }
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
